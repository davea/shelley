{
  "name": "shelley-ui",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "node scripts/build.js",
    "clean": "rm -rf dist/*",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "type-check:vue": "vue-tsc --noEmit -p tsconfig.vue.json",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,html}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,json,css,html}'",
    "test": "node scripts/run-tests.mjs",
    "generate-types": "cd .. && go run ./cmd/go2ts.go -o ui/src/generated-types.ts",
    "test:e2e": "pnpm run build && playwright test",
    "test:e2e:headed": "pnpm run build && playwright test --headed",
    "test:e2e:ui": "pnpm run build && playwright test --ui",
    "test:e2e:debug": "pnpm run build && playwright test --debug"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.0",
    "@pierre/diffs": "1.1.20",
    "@primeuix/themes": "^2.0.3",
    "@xterm/addon-fit": "0.12.0-beta.213",
    "@xterm/addon-web-links": "0.13.0-beta.213",
    "@xterm/xterm": "6.1.0-beta.213",
    "ansi_up": "^6.0.6",
    "dompurify": "^3.3.1",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "marked": "^17.0.3",
    "monaco-editor": "^0.44.0",
    "monaco-vim": "^0.4.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vue": "^3.5.38"
  },
  "comments": {
    "react": "react/react-dom are runtime deps only of src/excalidraw-skill.js, the self-contained Excalidraw bundle streamed into the output_iframe sandbox. The Shelley app frontend is Vue-only."
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.60.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "@vue/tsconfig": "^0.9.1",
    "esbuild": "^0.19.0",
    "esbuild-plugin-vue3": "^0.5.1",
    "eslint": "^9.35.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.1.3",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.43.0",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "shiki": "^3.22.0",
      "@shikijs/core": "^3.22.0",
      "@shikijs/engine-javascript": "^3.22.0",
      "@shikijs/transformers": "^3.22.0"
    },
    "patchedDependencies": {
      "@primevue/core@4.5.5": "patches/@primevue__core@4.5.5.patch"
    }
  }
}
